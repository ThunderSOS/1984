    <task id="35700" name="Give Video CPU to Watson">
        <trigger action="GIVE" actionObject="CPU" actionAdjective="VIDEO" npcId="35700"/>
        <conditions>
            <condition type="carrying" itemId="430">Watson tuts and says, "Don't waste my time, comrade."</condition>
        </conditions>
        <onSuccess>
            <consequence type="message">Watson says, "Thank you, comrade. I'm gonna need that."
                He stashes the CPU under the bench.
            </consequence>
            <consequence type="removeItemsFromInventory" itemIds="430"/>
            <consequence type="setGameState" key="watsonReceivedCpu" value="true"/>
            <consequence type="timeCost" timeCost="2"/>
            <!-- run event to show message if Stencil still needed --> 
            <consequence type="fireEvent" eventIds="35701"/>
        </onSuccess>
    </task>
    
    <task id="35701" name="Give Stencil to Watson">
        <trigger action="GIVE" actionObject="STENCIL" actionAdjective="CIRCUIT" npcId="35700"/>
        <conditions>
            <condition type="carrying" itemId="431">Watson tuts and says, "Don't waste my time, comrade."</condition>
        </conditions>
        <onSuccess>
            <consequence type="message">
                Watson says, "Careful with that! It's delicate."
                He stashes the stencil under the bench.
            </consequence>
            <consequence type="removeItemsFromInventory" itemIds="431"/>
            <consequence type="setGameState" key="watsonReceivedStencil" value="true"/>
            <consequence type="timeCost" timeCost="2"/>
            <!-- run event to show message if CPU still needed --> 
            <consequence type="fireEvent" eventIds="35702"/>
        </onSuccess>
    </task>
    
    <task id="35702" name="Pay Watson">
        <trigger action="PAY" npcId="35700"/>
        <conditions>
            <!-- Only allow payment if both required parts have been given -->
            <condition type="checkGameState" key="watsonReceivedPayment" value="false">Watson says, "You've already paid me, comrade."</condition>
            <condition type="checkBalance" amount="15">Watson says, "Have you got enough? Maybe sell a few things in the market."</condition>
            <!-- <condition type="playerHasCredits" amount="15">You don't have enough credits.</condition> -->
        </conditions>
        <onSuccess>
            <consequence type="message">You hand the notes over to Watson. "Right," he says. "I'll get the other bits, it'll be ready in an hour."</consequence>
            <consequence type="setGameState" key="watsonReceivedPayment" value="true"/>
            <consequence type="timeCost" timeCost="2"/>
            <consequence type="fireEvent" eventIds="35704" timeout="60"/>
            <consequence type="updateBalance" amount="-15.00"/>
        </onSuccess>
    </task>
        
