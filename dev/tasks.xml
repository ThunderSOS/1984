<?xml version="1.0" encoding="UTF-8"?>
<tasks>
    <task id="100" name="Open Winston's Desk">
        <trigger action="OPEN" actionObject="DESK" roomId="1"/>
        <conditions>
            <condition type="checkGameState" key="homeDeskOpen" value="false">The desk is already open.</condition>
        </conditions>
        <onSuccess>
            <!--<consequence type="revealItem" item="6"/> add hidden items -->
            <consequence type="message">You open the desk drawer.</consequence>
            <consequence type="setGameState" key="homeDeskOpen" value="true"/>
            <consequence type="addItemsToRoom" itemIds="6"/>
            <consequence type="removeItemsFromRoom" itemIds="5"/>
        </onSuccess>
    </task>
    
    <task id="101" name="Close Winston's Desk">
        <trigger action="CLOSE" actionObject="DESK" roomId="1"/>
        <conditions>
            <condition type="checkGameState" key="homeDeskOpen" value="true">It's already closed.</condition>
        </conditions>
        <onSuccess>
            <!--<consequence type="revealItem" item="6"/> add hidden items -->
            <consequence type="message">You close the desk drawer.</consequence>
            <consequence type="setGameState" key="homeDeskOpen" value="false"/>
            <consequence type="addItemsToRoom" itemIds="5"/>
            <consequence type="removeItemsFromRoom" itemIds="6"/>
        </onSuccess>
    </task>
    
    <task id="102" name="Attach Board to Telescreen">
        <trigger action="ATTACH|PLUG" actionObject="BOARD" actionObjectAdjective="ASSEMBLED" targetObject="TELESCREEN" roomId="1"/>
        <conditions>
            <condition type="checkGameState" key="boardInstalled" value="false">The board is already attached.</condition>
            <condition type="carrying" itemId="432">You don't have the assembled board.</condition>
        </conditions>
        <onSuccess>
            <consequence type="message">
                You carefully plug the reversed board into the slot on the side of the telescreen.
                It snaps in place with a soft click.
            </consequence>
            <consequence type="removeItemsFromInventory" itemIds="432"/>
            <consequence type="setGameState" key="boardInstalled" value="true"/>
            <consequence type="timeCost" timeCost="3"/>

            <!-- Now trigger the surveillance outcome event -->
            <consequence type="cycleEvent" key="task_10002_eventIndex" eventIds="100|101|102|103"/>
        </onSuccess>
    </task>
    
    <task id="103" name="Detach Board from Telescreen">
        <trigger action="DETACH|UNPLUG" actionObject="BOARD" actionObjectAdjective="ASSEMBLED" targetObject="TELESCREEN" roomId="1"/>
        <conditions>
            <condition type="checkGameState" key="boardInstalled" value="true">It's not attached.</condition>
        </conditions>
        <onSuccess>
            <consequence type="message">
                You carefully unplug the reversed board from your telescreen.
            </consequence>
            <consequence type="addItemsToInventory" itemIds="432"/>
            <consequence type="setGameState" key="boardInstalled" value="false"/>
            <consequence type="timeCost" timeCost="3"/>
        </onSuccess>
    </task>
        
    <task id="700" name="Unblock Mrs Parsons sink">
        <trigger action="UNBLOCK" actionObject="SINK" targetObject="PLUNGER" roomId="7"/>
        <conditions>
            <condition type="carrying" itemId="11">You need something to unblock it with.</condition>
            <condition type="roomHasItem" itemId="9">The sink is already unblocked.</condition>
        </conditions>
        <onSuccess>            
            <consequence type="message">
                You unblock the sink by extracting a revolting mass of human hair and rotting cabbage from the drain. 
                The putrid water immediately drains out and you run some fresh water to rinse it out. 
                The kitchen immediately smells better.
                
                Mrs Parsons says, "'ere you know, something funny happened to me Telescreen the other night, I think it's broke. 
                I was watching the report about the war and all of a sudden it went all dark and a message appeared saying debug or something."
                "I 'ad to watch the rest of the report in the kitchen. I think that's 'ow me sink got blocked."
                "I suppose I oughta report it to the Caretaker but I never seem to find the time, what with the kids an' all."
                She turns and heads back to her living room.
            </consequence>
            <consequence type="setGameState" key="mrsParsonsSinkUnblocked" value="true"/>
            <consequence type="updateRoomDescription" roomId="7">The smell of cabbage is somewhat reduced.</consequence>
            <consequence type="addItemsToRoom" itemIds="10"/>
            <consequence type="removeItemsFromRoom" itemIds="9"/>
            <consequence type="setNpcState" npcId="500" newState="3"/>
            <consequence type="timeCost" timeCost="10"/>
            <consequence type="moveNpc" npcId="500" roomId="6"/>
        </onSuccess>
    </task>
        
    <task id="1300" name="Open Caretakers Desk">
