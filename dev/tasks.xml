    <task id="10400" name="Distract patrols with rock">
        <trigger action="THROW" actionObject="ROCK" actionAdjective="LOOSE" targetObject="LAMP" roomId="104"/>
        <conditions>
            <condition type="carrying" itemId="101">You need something to throw at the lamp.</condition>
            <condition type="roomHasItem" itemId="102">The glass is already broken.</condition>
        </conditions>
        <onSuccess>
            <consequence type="message">
                You hurl the rock at the lantern and the glass shatters loudly, echoing across the park. 
                The patrols shout and rush toward the noise, leaving the southern path clear.
            </consequence>
            <consequence type="addExit" roomId="107" direction="E" toRoom="110" timeCost="2"/>
            <consequence type="addExit" roomId="104" direction="S" toRoom="110" timeCost="2"/>
            <consequence type="updateRoomDescription" roomId="107">
                The gravel path is cut by a Party patrol route but the patrols have abandoned the crossing and gone to investigate the noise of breaking glass. 
                A telescreen is mounted on a tree, its flickering face still watches the path.
            </consequence>
            <consequence type="updateRoomDescription" roomId="104">The remains of a bandstand rise like broken teeth, its roof long collapsed.
                A lamp post stands next to the bandstand, paint peeling and rusted beneath. It's been many years since it was last lit. 
                Shards of glass lie on the ground beneath it.
            </consequence>
            <consequence type="removeItemsFromInventory" itemIds="101"/>
            <consequence type="addItemsToRoom" itemIds="101|104"/>
            <consequence type="removeItemsFromRoom" itemIds="102"/>
            <consequence type="timeCost" timeCost="2"/>
        </onSuccess>
    </task>
    
    <task id="11000" name="Show flyer to prole">
        <trigger action="SHOW" actionObject="LEAFLET" npcId="11000"/>
        <conditions>
            <condition type="carrying" itemId="412">The prole tuts and says, "Don't waste my time, comrade."</condition>
        </conditions>
        <onSuccess>
            <consequence type="message">The prole says, "OK, wait a minute."</consequence>
            <consequence type="message">
                You watch as he leaves by an alley beside the National Gallery North towards Charing Cross Road.

                ...A few minutes pass...

                There's a tap on your shoulder and your blood runs cold, not the Thought Police already? 
                But a gaunt man with sharp eyes steps forward, "I'm Silas."
            </consequence>
            <consequence type="runNpcState" npcId="11000" newState="8"/>
            <!-- Bring Silas out of limbo and trigger his first state -->
            <consequence type="moveNpc" npcId="11001" roomId="110"/>
            <consequence type="moveNpc" npcId="11000" roomId="999"/>
            <consequence type="runNpcState" npcId="11001" newState="0"/>
            <consequence type="timeCost" timeCost="10"/>
        </onSuccess>
    </task>
        
