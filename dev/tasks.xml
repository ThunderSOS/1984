            <condition type="checkGameState" key="serviceDoorOpen" value="true">You need to open it first.</condition>
        </conditions>
        <onSuccess>
            <consequence type="message">The service door clicks closed.</consequence>
            <consequence type="removeExit" roomId="20" direction="W"/>
            <consequence type="removeExit" roomId="21" direction="E"/>
            <consequence type="addItemsToRoom" itemIds="17"/>
            <consequence type="removeItemsFromRoom" itemIds="18"/>
            <consequence type="setGameState" key="serviceDoorOpen" value="false"/>
        </onSuccess>
    </task>
    
