    <task id="54500">
        <trigger action="OPEN" actionObject="DESK" roomId="545"/>
        <conditions>
            <condition type="checkGameState" key="isSupervisorsDeskUnlocked" value="true">
                The desk is locked.
            </condition>
            <condition type="checkGameState" key="isSupervisorsDeskOpen" value="false">
                The desk is already open.
            </condition>
            <condition type="checkTime" startHour="22" endHour="7">
                It's far too dangerous to do this during the day!
            </condition>
        </conditions>
        <onSuccess>
            <consequence type="setGameState" key="isSupervisorsDeskOpen" value="false"/>
            <consequence type="removeItemsFromRoom" roomId="545" itemIds="509"/>
            <consequence type="addItemsToRoom" roomId="545" itemIds="510"/>
            <consequence type="message">
                You slide the drawer open.
            </consequence>
        </onSuccess>
    </task>
        
    <task id="54501">
        <trigger action="CLOSE" actionObject="DESK" roomId="545"/>
        <conditions>
            <condition type="checkGameState" key="isSupervisorsDeskOpen" value="false">
                The desk is already closed.
            </condition>
            <condition type="checkGameState" key="hasSmashedSupervisorsDesk" value="false">
                The desk drawer cannot be closed properly because of the lock. The best you can do is slide it back into place so that from a distance it looks normal. 
                You know that the subterfuge won't last. 
            </condition>
        </conditions>
        <onSuccess>
            <consequence type="setGameState" key="isSupervisorsDeskOpen" value="false"/>
            <consequence type="removeItemsFromRoom" roomId="545" itemIds="510"/>
            <consequence type="addItemsToRoom" roomId="545" itemIds="509"/>
            <consequence type="message">
                The drawer slides closed.
            </consequence>
        </onSuccess>
        <onFailed>
            <consequence type="setGameState" key="isSupervisorsDeskOpen" value="true"/>
        </onFailed>
    </task>
    
    <task id="54502">
        <trigger action="UNLOCK" actionObject="DESK|LOCK" targetObject="LOCKPICK" roomId="545"/>
        <conditions>
            <condition type="carrying" itemId="433">
                You need something to unlock it with.
            </condition>
            <blockIfNot type="checkGameState" key="isSupervisorsDeskUnlocked" value="false">
                The desk is already unlocked.
            </blockIfNot>
            <condition type="checkTime" startHour="22" endHour="7">
                It's far too dangerous to do that during the day!
            </condition>
        </conditions>
        <onSuccess>
            <consequence type="message">You've had little practice and the lockpick is difficult to use but after a few tries you succeed... The desk is unlocked!</consequence>
            <consequence type="setGameState" key="isSupervisorsDeskUnlocked" value="true"/>            
        </onSuccess>
    </task>
    
    <task id="54503">
        <trigger action="LOCK" actionObject="DESK|LOCK" targetObject="LOCKPICK" roomId="545"/>
        <conditions>
            <condition type="carrying" itemId="433">
                You need something to lock it with.
            </condition>
            <blockIfNot type="checkGameState" key="isSupervisorsDeskUnlocked" value="true">
                The desk is already locked.
            </blockIfNot>
            <blockIfNot type="checkGameState" key="hasSmashedSupervisorsDesk" value="true">
                The lock is smashed and no longer works. 
                The best you can do is fit the drawer back in place so at a distance it looks normal and just hope nobody figures out who did it.
            </blockIfNot>
        </conditions>
        <onSuccess>
            <consequence type="message">The lock clicks closed.</consequence>
            <consequence type="setGameState" key="isSupervisorsDeskUnlocked" value="false"/>
            <consequence type="setGameState" key="isSupervisorsDeskOpen" value="false"/>
        </onSuccess>
    </task>
    
    <task id="54504">
        <trigger action="SMASH|JEMMY|PRISE" actionObject="DESK|LOCK" targetObject="CROWBAR" roomId="545"/>
        <conditions>
            <condition type="carrying" itemId="400">
                You need something to prise the lock it with.
            </condition>
            <condition type="checkGameState" key="hasSmashedSupervisorsDesk" value="false">
                The lock has already been jemmied off.
            </condition>
            <blockIfNot type="checkGameState" key="isSupervisorsDeskUnlocked" value="false">
                There's no need to do that, the desk is already unlocked. 
            </blockIfNot>
            <blockIfNot type="checkGameState" key="isSupervisorsDeskOpen" value="false">
                There's no need to do that, the desk is already open. 
            </blockIfNot>
            <condition type="checkTime" startHour="22" endHour="7">
                It's far too dangerous to do that during the day!
            </condition>
        </conditions>
        <onSuccess>
            <consequence type="message">
                You prise the lock off with the crowbar
                The front of the drawer splits with the force you needed to use and you realise the enormity of what you've just done.
            </consequence>
            <consequence type="setGameState" key="isSupervisorsDeskUnlocked" value="true"/>
            <consequence type="setGameState" key="supervisorsDeskSmashed" value="true"/>
        </onSuccess>
    </task>
    
