    <task id="2000" name="Unlock service door">
        <trigger action="UNLOCK" actionObject="DOOR" actionAdjective="SERVICE" 
                 targetObject="KEY" targetAdjective="CARETAKERS" 
                 roomId="20"/>
        <conditions>
            <condition type="checkGameState" key="serviceDoorUnlocked" value="false">The door is already unlocked.</condition>
            <condition type="carrying" itemId="16">You need a key to unlock it with.</condition>
        </conditions>
        <onSuccess>
            <consequence type="message">The lock is well maintained and turns easily.</consequence>
            <consequence type="timeCost" timeCost="1"/>
            <consequence type="setGameState" key="serviceDoorUnlocked" value="true"/>
        </onSuccess>
    </task> 
    
    <task id="2001" name="Open service door">
        <trigger action="OPEN" actionObject="DOOR" actionAdjective="SERVICE" roomId="20"/>
        <conditions>
            <condition type="checkGameState" key="serviceDoorUnlocked" value="true">You need to unlock it first.</condition>
        </conditions>
        <onSuccess>
            <consequence type="message">The service door opens easily revealing a manhole leading down into the depths of the city.</consequence>
            <consequence type="addExit" roomId="20" direction="W" toRoom="21"/>
            <consequence type="addExit" roomId="21" direction="E" toRoom="20"/>
            <consequence type="addItemsToRoom" itemIds="18"/>
            <consequence type="removeItemsFromRoom" itemIds="17"/>
            <consequence type="setGameState" key="serviceDoorOpen" value="true"/>
            <consequence type="updateRoomDescription" roomId="21">
                A rusty iron ladder provides a way down to the tunnels below street level. 
                A heavy steel service door leads east.
            </consequence>
        </onSuccess>
    </task>
    
    <task id="2002" name="Close service door">
        <trigger action="CLOSE" actionObject="DOOR" actionAdjective="SERVICE" roomId="20"/>
