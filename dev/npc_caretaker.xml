<?xml version="1.0" encoding="UTF-8"?>
<npcs>     
    <npc id="1300" name="The Caretaker" altNames="CARETAKER">   
        
        <configuration initialRoom="13" initialState="1"/>       
        
        <properties>
            <property name="loop_exit" value="false"/>
        </properties>
          
        <state id="1" value="PASSIVE" evaluateUnless="loop_exit">
            <action type="message">The Caretaker looks disdainfully at you, "What's broken now?"</action>
            <action type="choice" validResponses="1|2|3">1) Report your telescreen as broken, 2) Report Mrs Parsons telescreen as broken, 3) Ignore</action>
            <action type="setNextState" nextState="2"/>
        </state>
        
        <state id="2">
            <action type="response" response="1" nextState="8"/>
            <action type="response" response="2" nextState="5"/>
            <action type="response" response="3" nextState="1">The caretaker looks annoyed, "Don't waste my time comrade."</action>
            <action type="setProperty" key="loop_exit" value="true"/>  
            <action type="timeCost" timeCost="1"/>     
            <action type="runNpcState"/>
        </state>

        <state id="5" value="CHECK PARSONS FLAG">
            <action type="checkGameState" key="mrsParsonsSinkUnblocked" onSuccess="10" onFailed="1">"How do you know?" He glares at you suspiciously.</action> 
        </state>
        
        <state id="6" value="IN MRS PARSONS FLAT">
            <action type="message">
                The Caretaker removes what looks like a circuit board from the side of the Telescreen and slips it into his overalls.
                He looks around at Mrs Parsons, "Should be alright now, any problems and give me a shout."
            </action>
            <action type="setNextState" nextState="7"/>
            <action type="moveNpc" npcId="1300" roomId="13"/>
            <action type="setDistracted" value="false"/>
            <action type="setProperty" key="loop_exit" value="false"/>
        </state>
        
        <!-- do nothing state when finished --> 
        <state id="7" value="WAITING"/>
        
        <state id="8" value="DISTRACTED YOUR FLAT">
            <action type="message">
                The Caretaker grunts, annoyed. "OK, I'll have a look."
                He leaves immediately.
            </action>
            <action type="moveNpc" npcId="1300" roomId="1"/> <!-- moves to your flat -->
            <action type="setNextState" nextState="9"/>
            <action type="setDistracted" value="true"/>
            <action type="timeCost" timeCost="2"/>
            <action type="setProperty" key="loop_exit" value="false"/>
        </state>
                
        <state id="9" value="IN YOUR FLAT">
            <action type="message">The Caretaker grunts, "I can't find anything wrong with it."</action>
            <action type="setNextState" nextState="1"/>
            <action type="moveNpc" npcId="1300" roomId="13"/>
            <action type="setDistracted" value="false"/>
            <action type="setProperty" key="loop_exit" value="false"/>
        </state>
		
        <state id="10" value="MOVE TO MRS PARSONS FLAT">
            <action type="message">
                The Caretaker grunts, annoyed. "I'd better check that out."
                He leaves immediately.
            </action>
            <action type="moveNpc" npcId="1300" roomId="6"/> <!-- moves to Mrs Parsons flat -->            
            <action type="setNextState" nextState="6"/>
            <action type="setDistracted" value="true"/>
            <action type="timeCost" timeCost="2"/>
        </state>
                
    </npc>
</npcs>