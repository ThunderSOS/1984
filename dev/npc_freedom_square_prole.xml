<?xml version="1.0" encoding="UTF-8"?>
<npcs>     
    <npc id="11000" name="The Prole Loiterer" initialRoom="110" initialState="1" altNames="PROLE|LOITERING PROLE|PROLE LOITERER">
        
        <configuration initialRoom="110" initialState="1"/>
        
        <properties>
            <property name="silas_loop_exit" value="false"/>
        </properties>
          
        <state id="1" value="PASSIVE" evaluateUnless="silas_loop_exit">
            <action type="message">A shabby prole leans against the cracked plinth, watching you curiously.</action>
            <action type="choice" validResponses="1|2|3">1) Ask about Silas, 2) Say you're just passing, 3) Ignore.</action>
            <action type="setNextState" nextState="2"/>            
        </state>
        
        <state id="2">
            <action type="response" response="1" nextState="3"/>
            <action type="response" response="2|3" nextState="1">The prole says, "Each to their own, comrade."</action>
            <action type="setProperty" key="silas_loop_exit" value="true"/>  
            <action type="runNpcState"/>
        </state>
        
        <state id="3" value="PASSIVE">		
            <action type="message">The prole says, "If you got a flyer, show it me. If you ain't, make yourself scarce."</action>
            <!-- clear state to reset back to the text input prompt --> 
            <action type="clearNpcResponse"/>
        </state>
                
        <state id="8" value="DONE"/>  
    </npc>
</npcs>

