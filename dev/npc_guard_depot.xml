<?xml version="1.0" encoding="UTF-8"?>
<npcs>     
    <npc id="15600" name="The Security Guard" altNames="GUARD|SECURITY GUARD"> 
        
        <configuration initialRoom="2" initialState="1">
            <combat hp="100" onAttack="2" onDeath="5"/>
        </configuration>
          
        <state id="1" value="INITIAL ATTACK" >
            <action type="message">A guard steps forward, gun pointed. "Where are you going?"</action>
            <action type="chance" chance="3" probabilitySpace="4" onSuccess="2" onFail="3"/>
        </state>
        
        <state id="2">
            <action type="message">He points his gun at you and fires!</action>
            <action type="playerDamage" amount="25"/>
            <action type="chance" chance="1" probabilitySpace="10" onSuccess="10" onFail="4"/>
        </state>
        
        <state id="3">
            <action type="message">He takes a step back and raises his gun. It's pointed at your chest.</action>
        </state>
        
        <state id="4">
            <action type="message">The bullet connects and nearly knocks you over with the force.</action>
            <action type="setNextState" nextState="7"/>
        </state>
        
        <state id="5">
            <action type="message">The guard finally falls to the ground. He's not breathing.</action>
            <action type="setNextState" nextState="7"/>
        </state>
        
        <!-- inert after death or just waiting for player -->
        <state id="7"/>
                      
        <!-- Puts you in Hospital -->                          
        <state id="10">
            <action type="message">
                The bullet enters your shoulder and the pain is excruciating. 
                Darkness closes in...
			
                ... Time passes ...
                
                Finally you wake up again, feeling whoozy. Your head aches. Your arm aches and is very stiff. 
            </action>
            <!--<action type="movePlayer" roomId="391"/>--> <!-- hospital -->
            <action type="setNextState" nextState="1"/>
            <action type="timeCost" timeCost="90"/>
        </state>     
    </npc>
</npcs>